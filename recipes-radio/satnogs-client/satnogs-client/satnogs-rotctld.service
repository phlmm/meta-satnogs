[Unit]
Description=SatNOGS rotctld service
After=network.target

[Service]
Type=simple
User=satnogs
Group=satnogs
EnvironmentFile=-/etc/default/satnogs-client
ExecStart=/usr/bin/rotctld -m ${SATNOGS_ROT_MODEL} -r ${SATNOGS_ROT_IP} -t 4533
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
